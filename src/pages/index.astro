---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import AvailabilityCalendar from '~/components/AvailabilityCalendar.astro';

import ImageCarousel from '~/components/ImageCarousel.astro';

import alpenblick_1 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-1.jpg';
import alpenblick_2 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-2.jpg';
import alpenblick_3 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-3.jpg';
import alpenblick_4 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-4.jpg';
import alpenblick_5 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-5.jpg';
import alpenblick_6 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-6.jpg';
import alpenblick_7 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-7.jpg';
import alpenblick_8 from '~/assets/images/apartments/alpenpanorama/alpenpanorama-8.jpg';

import bergblick_1 from '~/assets/images/apartments/bergwiese/bergwiese-1.jpg';
import bergblick_2 from '~/assets/images/apartments/bergwiese/bergwiese-2.jpg';
import bergblick_3 from '~/assets/images/apartments/bergwiese/bergwiese-3.jpg';
import bergblick_4 from '~/assets/images/apartments/bergwiese/bergwiese-4.jpg';
import bergblick_5 from '~/assets/images/apartments/bergwiese/bergwiese-5.jpg';
import bergblick_6 from '~/assets/images/apartments/bergwiese/bergwiese-6.jpg';

import lh1 from '~/assets/images/landhaus/bauernhof-01.jpg';
import lh2 from '~/assets/images/landhaus/bauernhof-02.jpg';
import lh3 from '~/assets/images/landhaus/bauernhof-03.jpg';
import lh4 from '~/assets/images/landhaus/bauernhof-04.jpg';
import lh5 from '~/assets/images/landhaus/bauernhof-05.jpg';
import lh6 from '~/assets/images/landhaus/bauernhof-06.jpg';

const alpenblickImages = [
  { src: alpenblick_1, alt: 'Alpenblick 1' },
  { src: alpenblick_2, alt: 'Alpenblick 2' },
  { src: alpenblick_3, alt: 'Alpenblick 3' },
  { src: alpenblick_4, alt: 'Alpenblick 4' },
  { src: alpenblick_5, alt: 'Alpenblick 5' },
  { src: alpenblick_6, alt: 'Alpenblick 6' },
  { src: alpenblick_7, alt: 'Alpenblick 7' },
  { src: alpenblick_8, alt: 'Alpenblick 8' },
];

const bergblickImages = [
  { src: bergblick_1, alt: 'Bergblick 1' },
  { src: bergblick_2, alt: 'Bergblick 2' },
  { src: bergblick_3, alt: 'Bergblick 3' },
  { src: bergblick_4, alt: 'Bergblick 4' },
  { src: bergblick_5, alt: 'Bergblick 5' },
  { src: bergblick_6, alt: 'Bergblick 6' },
];

const landhausImages = [
  { src: lh1, alt: 'Haus Sonnenschein Landhaus' },
  { src: lh2, alt: 'Haus Sonnenschein Garten' },
  { src: lh3, alt: 'Haus Sonnenschein Terrasse' },
  { src: lh4, alt: 'Haus Sonnenschein Umgebung' },
  { src: lh5, alt: 'Haus Sonnenschein Aussicht' },
  { src: lh6, alt: 'Haus Sonnenschein Eingang' },
];

const metadata = {
  title: 'Haus Sonnenschein – Ferienwohnungen in Aschau im Chiemgau',
  ignoreTitleTemplate: true,
};
---

<!-- BFW-352: tenant slug + public API base URL for the AvailabilityCalendar widget.
     BFW-532: bookings snapshot embedded so the calendar renders from static HTML
     even when the runtime fetch is blocked (Chrome PNA, mixed content, offline).
     Markers are replaced by WebsiteContentReplacer at publish time. -->
<script is:inline define:vars={{ tenantSlug: '640065', apiBase: 'http://localhost:9080', bookingsRaw: '[{"apartmentSlug":"alpenblick","startDate":"2026-06-12","endDate":"2026-06-22","status":"BOOKED"},{"apartmentSlug":"alpenblick","startDate":"2026-05-28","endDate":"2026-06-11","status":"BOOKED"},{"apartmentSlug":"alpenblick","startDate":"2026-05-15","endDate":"2026-05-27","status":"BOOKED"},{"apartmentSlug":"alpenblick","startDate":"2026-05-11","endDate":"2026-05-14","status":"BOOKED"},{"apartmentSlug":"bergblick","startDate":"2026-05-29","endDate":"2026-06-06","status":"BOOKED"},{"apartmentSlug":"bergblick","startDate":"2026-05-18","endDate":"2026-05-28","status":"BOOKED"},{"apartmentSlug":"bergblick","startDate":"2026-05-15","endDate":"2026-05-17","status":"BOOKED"},{"apartmentSlug":"bergblick","startDate":"2026-05-04","endDate":"2026-05-10","status":"BOOKED"}]' }}>
  window.MFWS_TENANT_SLUG = tenantSlug;
  window.MFWS_PUBLIC_API_BASE_URL = apiBase;
  try {
    window.MFWS_INITIAL_BOOKINGS = bookingsRaw && bookingsRaw.charAt(0) === '[' ? JSON.parse(bookingsRaw) : [];
  } catch (e) {
    window.MFWS_INITIAL_BOOKINGS = [];
  }
</script>

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'secondary',
        text: 'Buchungsanfrage',
        href: '/contact',
        icon: 'tabler:mail',
      },
      { variant: 'primary', text: 'Wohnungen ansehen', href: '#ferienwohnungen' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Haus Sonnenschein – Ferienwohnungen in Aschau im Chiemgau' }}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-white">Willkommen im Haus Sonnenschein</span>
    </Fragment>

    <Fragment slot="subtitle">
      Erholung pur am Chiemsee
    </Fragment>
  </Hero>

  <!-- Ferienwohnungen Section *************** -->

  <section id="ferienwohnungen" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Ferienwohnungen</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">Ihre Ferienwohnungen in Aschau im Chiemgau</h2>
        <p class="text-lg text-muted dark:text-slate-400">
          Nichtraucher-Haus. Haustiere auf Anfrage. Parkplatz vorhanden.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-lg text-default dark:text-slate-300 mb-8">
        <span class="flex items-center gap-1.5"><Icon name="tabler:trees" class="w-4 h-4" /> Garten</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sun" class="w-4 h-4" /> Terrasse</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:car" class="w-4 h-4" /> Parkplatz</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:paw" class="w-4 h-4" /> Haustiere erlaubt</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:flame" class="w-4 h-4" /> Grill</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:mood-kid" class="w-4 h-4" /> Kinder willkommen</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sparkles" class="w-4 h-4" /> 2025 renoviert</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={alpenblickImages} id="alpenblick" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Alpenblick</h3>
            <p class="text-sm text-muted dark:text-slate-400 mb-3">Unsere größte Wohnung im Erdgeschoss mit schönem Blick auf die Alpen. Ideal für Familien.</p>
            <p class="text-sm font-semibold text-primary mb-3">Ab 75 € / Nacht (1-2 Pers.) · inkl. 7 % USt</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-3.5 h-3.5" /> 110 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-3.5 h-3.5" /> Wohnzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Einzelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> WLAN</span>
            </div>
            <AvailabilityCalendar apartment="alpenblick" id="alpenblick" />
            <div class="mt-4 border-t border-gray-200 dark:border-slate-700 pt-4">
              <div class="flex flex-wrap gap-3 mb-3">
                <div>
                  <label for="bfw-pc-checkin-alpenblick" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Anreise</label>
                  <input type="date" id="bfw-pc-checkin-alpenblick" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
                <div>
                  <label for="bfw-pc-checkout-alpenblick" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Abreise</label>
                  <input type="date" id="bfw-pc-checkout-alpenblick" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <p id="bfw-pc-date-error-alpenblick" class="hidden text-xs text-red-600 mb-2">Mindestens 1 Übernachtung</p>
              <button type="button" id="bfw-pc-cta-alpenblick" disabled class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Buchungsanfrage</button>
            </div>
<script>
(function() {
  var checkinInput = document.getElementById('bfw-pc-checkin-alpenblick');
  var checkoutInput = document.getElementById('bfw-pc-checkout-alpenblick');
  var dateError = document.getElementById('bfw-pc-date-error-alpenblick');
  var ctaButton = document.getElementById('bfw-pc-cta-alpenblick');

  var APARTMENT_SLUG = 'alpenblick';
  var CONTACT_PATH = '/contact';

  function todayStr() {
    var d = new Date();
    return d.toISOString().split('T')[0];
  }

  function dayAfter(isoDate) {
    var d = new Date(isoDate + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    return d.toISOString().split('T')[0];
  }

  function datesValid() {
    var ci = checkinInput ? checkinInput.value : '';
    var co = checkoutInput ? checkoutInput.value : '';
    return !!ci && !!co && co > ci && ci >= todayStr();
  }

  function showDateError(show) {
    if (!dateError) return;
    if (show) dateError.classList.remove('hidden');
    else dateError.classList.add('hidden');
  }

  function updateButtonState() {
    if (ctaButton) ctaButton.disabled = !datesValid();
  }

  function refreshErrorAndButton() {
    var ci = checkinInput ? checkinInput.value : '';
    var co = checkoutInput ? checkoutInput.value : '';
    // Show "min 1 night" error only when both dates are picked AND departure ≤ arrival.
    showDateError(!!ci && !!co && co <= ci);
    updateButtonState();
  }

  if (checkinInput) checkinInput.min = todayStr();
  if (checkoutInput) checkoutInput.min = dayAfter(todayStr());

  function onCheckinChange() {
    if (checkinInput && checkinInput.value && checkoutInput) {
      var minOut = dayAfter(checkinInput.value);
      checkoutInput.min = minOut;
      if (checkoutInput.value && checkoutInput.value < minOut) {
        checkoutInput.value = '';
      }
    }
    refreshErrorAndButton();
  }

  function onCheckoutChange() {
    refreshErrorAndButton();
  }

  if (checkinInput) checkinInput.addEventListener('change', onCheckinChange);
  if (checkoutInput) checkoutInput.addEventListener('change', onCheckoutChange);

  if (ctaButton) {
    ctaButton.addEventListener('click', function() {
      if (!datesValid()) return;
      try {
        sessionStorage.setItem('mfws_booking_draft', JSON.stringify({
          apartmentSlug: APARTMENT_SLUG,
          checkIn: checkinInput.value,
          checkOut: checkoutInput.value,
        }));
      } catch (e) { /* sessionStorage may be disabled — fall through */ }
      window.location.href = CONTACT_PATH;
    });
  }

  refreshErrorAndButton();
})();
</script>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={bergblickImages} id="bergblick" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Bergblick</h3>
            <p class="text-sm text-muted dark:text-slate-400 mb-3">Gemütliche Wohnung im Erdgeschoss mit Blick auf den Garten. Ideal für eine Auszeit zu zweit.</p>
            <p class="text-sm font-semibold text-primary mb-3">Ab 60 € / Nacht (1-2 Pers.) · inkl. 7 % USt</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted dark:text-slate-400 mb-4">
              <span class="flex items-center gap-1"><Icon name="tabler:maximize" class="w-3.5 h-3.5" /> 20 m²</span>
              <span class="flex items-center gap-1"><Icon name="tabler:sofa" class="w-3.5 h-3.5" /> Wohnzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Schlafzimmer</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Doppelbett</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Küche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bad</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Dusche</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Badewanne</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> WLAN</span>
            </div>
            <AvailabilityCalendar apartment="bergblick" id="bergblick" />
            <div class="mt-4 border-t border-gray-200 dark:border-slate-700 pt-4">
              <div class="flex flex-wrap gap-3 mb-3">
                <div>
                  <label for="bfw-pc-checkin-bergblick" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Anreise</label>
                  <input type="date" id="bfw-pc-checkin-bergblick" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
                <div>
                  <label for="bfw-pc-checkout-bergblick" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Abreise</label>
                  <input type="date" id="bfw-pc-checkout-bergblick" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <p id="bfw-pc-date-error-bergblick" class="hidden text-xs text-red-600 mb-2">Mindestens 1 Übernachtung</p>
              <button type="button" id="bfw-pc-cta-bergblick" disabled class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Buchungsanfrage</button>
            </div>
<script>
